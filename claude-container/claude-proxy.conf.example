# vLLM service URL (OpenAI-compatible protocol)
VLLM_URL=http://localhost:8000/v1

# Model name on vLLM (also used as Claude Code model name)
MODEL=glm-5

# API key (keep default if vLLM has no auth)
API_KEY=sk-placeholder

# claude-code-proxy listen port
PROXY_PORT=8082

# Debug mode: set to 1 to enable request/response logging proxy
# Logs model mapping, tool calls, and responses to /var/log/debug-proxy.log
#DEBUG=1

# Full debug: set to 1 to log complete request/response bodies
# Written to /var/log/debug-proxy-full.log (can be very large)
#DEBUG_FULL=1
