# LLM service URL (OpenAI-compatible protocol, e.g. vLLM, SGLang)
VLLM_URL=http://localhost:8000/v1

# Model name on the LLM service (also used as Claude Code model name)
MODEL=glm-5

# API key (keep default if provider has no auth)
API_KEY=sk-placeholder

# Custom claude-code-router config (optional)
# Mount your config.json to this path; if not set, auto-generated from above settings
# Example: docker run -v ./my-router-config.json:/etc/claude-router-config.json ...
#ROUTER_CONFIG=/etc/claude-router-config.json

# Debug mode: set to 1 to enable two-layer debug proxy with full request/response logging
# Logs to /var/log/cc2ccr.log (Anthropic layer) and /var/log/ccr2provider.log (OpenAI layer)
#DEBUG=1
